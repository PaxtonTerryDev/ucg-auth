{
  "tasks": {
    "setup": "deno run -A --env-file=env.env/database.local/env ./scripts/setup.ts",
    "api:dev": "deno run -A --env-file=env/api.local.env --env-file=env/database.local.env --watch src/api/server.ts",
    "auth:generate": "deno run -A --env-file=env/database.local.env --env-file=env/api.local --env=.env npm:auth generate --config ./src/api/auth.ts --output ./src/database/schema.prisma",
    "db:format": "deno run -A --env-file=env/database.local.env --env=.env npm:prisma format",
    "db:generate": "deno run -A --env-file=env/database.local.env --env=.env npm:prisma generate",
    "db:push": "deno run -A --env-file=env/database.local.env --env=.env npm:prisma db push",
    "db:migrate": "deno run -A --env-file=env/database.local.env --env=.env npm:prisma migrate dev",
    "db:seed": "deno run -A --env-file=env/database.local.env --env=.env npm:prisma db seed"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "deno.window"
    ],
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "imports": {
    "@api/": "./src/api/",
    "@schemas/": "./src/schemas/",
    "@better-auth/oauth-provider": "npm:@better-auth/oauth-provider@^1.6.10",
    "@cli/": "./src/cli/",
    "@cliffy/command": "jsr:@cliffy/command@^1.1.0",
    "@lib/": "./src/lib/",
    "@database/": "./src/database/",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.8.0",
    "@prisma/client": "npm:@prisma/client@^7.8.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "better-auth": "npm:better-auth@^1.6.10",
    "hono": "npm:hono@^4.12.18",
    "picocolors": "npm:picocolors@^1.1.1",
    "prisma": "npm:prisma@^7.8.0",
    "zod": "npm:zod@^4.4.3"
  },
  "allowScripts": [
    "npm:@prisma/engines@7.8.0",
    "npm:prisma@7.8.0"
  ]
}
