{
  "name": "@ucg-auth/database",
  "private": true,
  "type": "module",
  "exports": {
    "./prisma": "./src/prisma.ts",
    "./repositories": "./src/repositories/index.ts",
    "./config": "./src/config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@ucg-auth/lib": "workspace:*",
    "@ucg-auth/schemas": "workspace:*"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "db:generate": "prisma generate --config=./prisma.config.ts",
    "db:format": "prisma format --config=./prisma.config.ts",
    "db:push": "dotenv-cli -e ../../env/database.local.env -- prisma db push --config=./prisma.config.ts",
    "db:migrate": "dotenv-cli -e ../../env/database.local.env -- prisma migrate dev --config=./prisma.config.ts"
  }
}
